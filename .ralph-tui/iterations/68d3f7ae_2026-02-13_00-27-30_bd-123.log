    46→            <label className=\"block text-lg font-bold text-gray-700 mb-1\">Room Name</label>\n    47→            <input\n    48→              type=\"text\"\n    49→              value={room}\n    50→              onChange={(e) => setRoom(e.target.value)}\n    51→              placeholder=\"Pick a room name\"\n    52→              maxLength={30}\n    53→              className=\"kid-input\"\n    54→              onKeyDown={(e) => {\n    55→                if (e.key === \"Enter\" && canSubmit) onJoin(username.trim(), room.trim(), avatar);\n    56→              }}\n    57→            />\n    58→          </div>\n    59→\n    60→          <div>\n    61→            <label className=\"block text-lg font-bold text-gray-700 mb-2\">Pick Your Animal</label>\n    62→            <AvatarPicker selected={avatar} onSelect={setAvatar} />\n    63→          </div>\n    64→        </div>\n    65→\n    66→        <motion.button\n    67→          whileHover={{ scale: 1.03 }}\n    68→          whileTap={{ scale: 0.97 }}\n    69→          onClick={() => canSubmit && onJoin(username.trim(), room.trim(), avatar)}\n    70→          disabled={!canSubmit}\n    71→          className=\"big-button w-full\"\n    72→        >\n    73→          Join Room!\n    74→        </motion.button>\n    75→      </div>\n    76→    </motion.div>\n    77→  );\n    78→}\n    79→"}]},"parent_tool_use_id":null,"session_id":"d19d0d50-9704-46f6-bffb-0ec216b7a8ca","uuid":"46a3b0ba-ce60-49d4-b661-8047e8fe6d3f","tool_use_result":{"type":"text","file":{"filePath":"/Users/thom/10-19_projects/upidstay/src/components/join-form.tsx","content":"\"use client\";\n\nimport { useState } from \"react\";\nimport { motion } from \"framer-motion\";\nimport { AvatarPicker } from \"./avatar-picker\";\nimport type { AvatarId } from \"@/lib/types\";\n\ninterface JoinFormProps {\n  onJoin: (username: string, room: string, avatar: AvatarId) => void;\n}\n\nexport function JoinForm({ onJoin }: JoinFormProps) {\n  const [username, setUsername] = useState(\"\");\n  const [room, setRoom] = useState(\"\");\n  const [avatar, setAvatar] = useState<AvatarId>(\"bear\");\n\n  const canSubmit = username.trim().length > 0 && room.trim().length > 0;\n\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 30 }}\n      animate={{ opacity: 1, y: 0 }}\n      className=\"w-full max-w-md mx-auto\"\n    >\n      <div className=\"bg-white rounded-3xl shadow-xl p-8 space-y-6\">\n        <div className=\"text-center\">\n          <h1 className=\"text-5xl font-black text-pink-500 tracking-tight\">Upidstay</h1>\n          <p className=\"text-xl text-gray-500 mt-1\">Ig-Pay Atin-Lay Alkie-Talkieway!</p>\n        </div>\n\n        <div className=\"space-y-4\">\n          <div>\n            <label className=\"block text-lg font-bold text-gray-700 mb-1\">Your Name</label>\n            <input\n              type=\"text\"\n              value={username}\n              onChange={(e) => setUsername(e.target.value)}\n              placeholder=\"What's your name?\"\n              maxLength={20}\n              className=\"kid-input\"\n              autoFocus\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-lg font-bold text-gray-700 mb-1\">Room Name</label>\n            <input\n              type=\"text\"\n              value={room}\n              onChange={(e) => setRoom(e.target.value)}\n              placeholder=\"Pick a room name\"\n              maxLength={30}\n              className=\"kid-input\"\n              onKeyDown={(e) => {\n                if (e.key === \"Enter\" && canSubmit) onJoin(username.trim(), room.trim(), avatar);\n              }}\n            />\n          </div>\n\n          <div>\n            <label className=\"block text-lg font-bold text-gray-700 mb-2\">Pick Your Animal</label>\n            <AvatarPicker selected={avatar} onSelect={setAvatar} />\n          </div>\n        </div>\n\n        <motion.button\n          whileHover={{ scale: 1.03 }}\n          whileTap={{ scale: 0.97 }}\n          onClick={() => canSubmit && onJoin(username.trim(), room.trim(), avatar)}\n          disabled={!canSubmit}\n          className=\"big-button w-full\"\n        >\n          Join Room!\n        </motion.button>\n      </div>\n    </motion.div>\n  );\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
