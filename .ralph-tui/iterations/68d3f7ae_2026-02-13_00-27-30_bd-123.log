{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jr9LnDX6EcYJz6JhidWapH","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useState, useCallback } from \"react\";\n     4→import { SocketProvider, useSocket } from \"@/lib/socket-context\";\n     5→import { JoinForm } from \"@/components/join-form\";\n     6→import { ChatRoom } from \"@/components/chat-room\";\n     7→import { PracticeMode } from \"@/components/practice-mode\";\n     8→import type { AvatarId } from \"@/lib/types\";\n     9→import { playJoinSound } from \"@/lib/sounds\";\n    10→import { motion } from \"framer-motion\";\n    11→\n    12→type View = \"home\" | \"chat\" | \"practice\";\n    13→\n    14→function AppContent() {\n    15→  const [view, setView] = useState<View>(\"home\");\n    16→  const [username, setUsername] = useState(\"\");\n    17→  const { joinRoom, connected } = useSocket();\n    18→\n    19→  const handleJoin = useCallback(\n    20→    (name: string, room: string, avatar: AvatarId) => {\n    21→      setUsername(name);\n    22→      joinRoom(room, name, avatar);\n    23→      playJoinSound();\n    24→      setView(\"chat\");\n    25→    },\n    26→    [joinRoom]\n    27→  );\n    28→\n    29→  if (view === \"practice\") {\n    30→    return <PracticeMode onBack={() => setView(\"home\")} soundEnabled={true} />;\n    31→  }\n    32→\n    33→  if (view === \"chat\") {\n    34→    return <ChatRoom username={username} onLeave={() => setView(\"home\")} />;\n    35→  }\n    36→\n    37→  return (\n    38→    <div className=\"min-h-screen bg-gradient-to-b from-pink-50 via-purple-50 to-sky-50 flex flex-col items-center justify-center p-6\">\n    39→      <JoinForm onJoin={handleJoin} />\n    40→      <motion.button\n    41→        whileHover={{ scale: 1.03 }}\n    42→        whileTap={{ scale: 0.97 }}\n    43→        onClick={() => setView(\"practice\")}\n    44→        className=\"mt-6 text-lg font-bold text-purple-400 hover:text-purple-600 transition-colors\"\n    45→      >\n    46→        Practice Mode (solo)\n    47→      </motion.button>\n    48→      {!connected && (\n    49→        <div className=\"mt-4 text-sm text-red-400\">Connecting to server...</div>\n    50→      )}\n    51→    </div>\n    52→  );\n    53→}\n    54→\n    55→export default function Home() {\n    56→  return (\n    57→    <SocketProvider>\n    58→      <AppContent />\n    59→    </SocketProvider>\n    60→  );\n    61→}\n    62→"}]},"parent_tool_use_id":null,"session_id":"d19d0d50-9704-46f6-bffb-0ec216b7a8ca","uuid":"093028fa-4312-48a7-bcd8-3c8bc35f7944","tool_use_result":{"type":"text","file":{"filePath":"/Users/thom/10-19_projects/upidstay/src/app/page.tsx","content":"\"use client\";\n\nimport { useState, useCallback } from \"react\";\nimport { SocketProvider, useSocket } from \"@/lib/socket-context\";\nimport { JoinForm } from \"@/components/join-form\";\nimport { ChatRoom } from \"@/components/chat-room\";\nimport { PracticeMode } from \"@/components/practice-mode\";\nimport type { AvatarId } from \"@/lib/types\";\nimport { playJoinSound } from \"@/lib/sounds\";\nimport { motion } from \"framer-motion\";\n\ntype View = \"home\" | \"chat\" | \"practice\";\n\nfunction AppContent() {\n  const [view, setView] = useState<View>(\"home\");\n  const [username, setUsername] = useState(\"\");\n  const { joinRoom, connected } = useSocket();\n\n  const handleJoin = useCallback(\n    (name: string, room: string, avatar: AvatarId) => {\n      setUsername(name);\n      joinRoom(room, name, avatar);\n      playJoinSound();\n      setView(\"chat\");\n    },\n    [joinRoom]\n  );\n\n  if (view === \"practice\") {\n    return <PracticeMode onBack={() => setView(\"home\")} soundEnabled={true} />;\n  }\n\n  if (view === \"chat\") {\n    return <ChatRoom username={username} onLeave={() => setView(\"home\")} />;\n  }\n\n  return (\n    <div className=\"min-h-screen bg-gradient-to-b from-pink-50 via-purple-50 to-sky-50 flex flex-col items-center justify-center p-6\">\n      <JoinForm onJoin={handleJoin} />\n      <motion.button\n        whileHover={{ scale: 1.03 }}\n        whileTap={{ scale: 0.97 }}\n        onClick={() => setView(\"practice\")}\n        className=\"mt-6 text-lg font-bold text-purple-400 hover:text-purple-600 transition-colors\"\n      >\n        Practice Mode (solo)\n      </motion.button>\n      {!connected && (\n        <div className=\"mt-4 text-sm text-red-400\">Connecting to server...</div>\n      )}\n    </div>\n  );\n}\n\nexport default function Home() {\n  return (\n    <SocketProvider>\n      <AppContent />\n    </SocketProvider>\n  );\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
